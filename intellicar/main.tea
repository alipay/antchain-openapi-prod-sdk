// 充电报告查询
model BatteryReport {
  // 充电单号，最大长度/规则：32
  startChargeSeq: string(name='start_charge_seq', example='202603031234567890'),
  // VIN，最大长度/规则：17位
  vinCode: string(name='vin_code', example='LFV3A2***3123456'),
  // 公告号，最大长度/规则36
  publicationNo?: string(name='publication_no', example='BJ7000USD3-BEV'),
  // 本次累积充电量，单位kWh；最大长度/规则：整数位<=10,小数位<=2
  totalPower?: string(name='total_power', example='25.30'),
  // 本次累积充入SOC（%）；最大长度/规则：0-100,小数位<=2
  totalChargeSoc?: string(name='total_charge_soc', example='50.00'),
  // 本次充电开始SOC(%)；最大长度/规则：0-100,小数位<=2
  startSoc?: string(name='start_soc', example='25.00'),
  // 本次充电截止SOC(%)；最大长度/规则：0-100,小数位<=2
  endSoc?: string(name='end_soc', example='75.00'),
  // 标称能量，单位kWh；最大长度/规则：0-1000,小数位<=2
  nominalEnergy?: string(name='nominal_energy', example='60.00'),
  // 充电城市ID；最大长度/规则：30
  cityId?: string(name='city_id', example='-'),
  // 注册日期；最大长度/规则：yyyy-MM-dd
  registerDate?: string(name='register_date', example='2018-10-10'),
}

// 高德潜客请求req
model GdCustomerFlow {
  // 当前页面
  current: long(name='current', example='1'),
  // 数据类型（SHOP：店铺；CITY：城市；PROVINCE：省份；COUNTRY：全国；SHOP_BRAND：店铺品牌(仅限竞品)）
  dataType: string(name='data_type', example='SHOP'),
  // 时间类型（DAY：天；WEEK：周；MONTH：月；仅针对城市和店铺品牌的竞品数据支持的时间类型为，季度：QUARTER；半年：HALF；年：YEAR）
  timeType: string(name='time_type', example='DAY'),
  // 主品牌id
  mainBrand: string(name='main_brand', example='102'),
  // 时间（时间类型为天时：yyyyMMdd；时间类型为周时：yyyyWW；时间类型为月时：yyyyMM；时间类型为季度时：yyyyQQ；时间类型为半年时：yyyyBB；时间类型为年时：yyyy；）
  time: string(name='time', example='20230103'),
  // 品牌id，以”,”分隔
  brandLimit: string(name='brand_limit', example='102'),
  // 数据指数类型（pv、uv中选择，多个以”,”分隔）
  dataLimit: string(name='data_limit', example='pv,uv'),
  // 数据统计逻辑（0：默认值，基于本品或竞品获取；1：基于本品获取）
  baseSelf?: long(name='base_self', example='1'),
}

// 二手车估价信息
model UsedCarValuation {
  // 评估金额(万)
  referenceprice: string(name='referenceprice', example='1.15-1.43'),
  // 官方报价(参考)(万)
  newcarprice: string(name='newcarprice', example='54.5'),
  // 车型图片(参考)
  url: string(name='url', example='"http://car0.autoimg.cn/cardfs/product/g32/M08/A5/55/t_autohomecar__ChxkPmZijMqAMuHJAALTBQ2Tti4239.jpg"'),
  // 车况好(万)(三个价格用"-"分隔,第一个是较小值第二个是...
  conditiona: string(name='conditiona', example='1.30-1.38-1.45'),
  // 车况正常(万)
  conditionb: string(name='conditionb', example='1.18-1.29-1.41'),
  // 车况差(万)
  conditionc: string(name='conditionc', example='1.04-1.16-1.28'),
}

// 键值对
model XNameValuePair {
  // 键名
  name: string(name='name', example='key'),
  // 键值
  value: string(name='value', example='value'),
}

