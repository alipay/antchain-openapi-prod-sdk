// 电池报告返回数据详情
model BatteryReportData {
  // VIN码
  vinCode: string(name='vin_code', example='-'),
  // 评估时间，报告生成时间 yyyy-MM-dd HH:mm:ss
  evaluateTime: string(name='evaluate_time', example='-'),
  // 当前 SOH（%），数值 0-100
  currentSoh: string(name='current_soh', example='12'),
  // SOH 评级：优秀 100-95 良好 95-90 中等 90-85 较差 85-80 差 80 以下
  sohLvStr: string(name='soh_lv_str', example='-'),
  // 电池衰退水平值
  volumeScoreRecession: string(name='volume_score_recession', example='1'),
  // 安全风险水平：低 较低 较高 高
  volumeScoreRecessionLvStr: string(name='volume_score_recession_lv_str', example='-'),
  // 安全风险水平解读文案
  volumeScoreRecessionNarrate: string(name='volume_score_recession_narrate', example='-'),
  // 保障状态 0：未保障 1：保障中 2：保障结束
  safeguardStatus: long(name='safeguard_status', example=''),
  // 保障截止期 yyyy-MM-dd HH:mm:ss
  safeguardEndTime: string(name='safeguard_end_time', example='-'),
  // 本轮首检 SOH（%）数值 0-100
  initialSoh: string(name='initial_soh', example='1'),
  // 本轮首检 评估时间 yyyy-MM-dd HH:mm:ss
  initialSohEvaluateTime: string(name='initial_soh_evaluate_time', example='-'),
  // 本轮首检 充电单号
  initialChargeSeq: string(name='initial_charge_seq', example='-'),
  // 触发赔付 SOH（%），数值 0-100
  sageguardMaxSubSoh: string(name='sageguard_max_sub_soh', example='1'),
  // 是否触发赔付，当前 SOH≤触发赔付 SOH 时为 true
  compensationTriggered: boolean(name='compensation_triggered', example='true, false'),
  // SOH 衰退预测-X 轴标题（年）
  yearSohTitle: [ string ](name='year_soh_title', example=''),
  // 本车电池衰退预测，逐年 SOH（%）
  curEstimateYearSoh: [ string ](name='cur_estimate_year_soh', example=''),
  // 同类型车电池衰退预测，逐年 SOH（%）
  peerEstimateYearSoh: [ string ](name='peer_estimate_year_soh', example=''),
  // 电池厂商
  batteryManufacturer: string(name='battery_manufacturer', example='-'),
  // 标称能量，单位 kWh
  nominalEnergy: string(name='nominal_energy', example='1'),
  // 标称容量，单位 Ah
  rateCapacity: string(name='rate_capacity', example='1'),
  // 电池类型
  batteryType: string(name='battery_type', example='-'),
  // 车辆生产年份
  manufacturerDate: string(name='manufacturer_date', example='-'),
  // 权益说明文案
  rightsDesc: string(name='rights_desc', example='-'),
}

// 高德数据集合内record
model GdCustomersRecord {
  // 城市编码，数据类型为店铺或者城市时返回该属性与值
  citycode: string(name='citycode', example='021'),
  // 品牌id
  brandId: string(name='brand_id', example='104'),
  // 店铺id，数据类型为店铺或者店铺品牌时返回该属性与值
  shopId: string(name='shop_id', example='26nhJ8duzh'),
  // 时间（时间类型为天时：yyyyMMdd；时间类型为周时：yyyyWW；时间类型为月时：yyyyMM）
  time: string(name='time', example='20230102'),
  // 重叠指数集合
  overlapList: [ Overlap ](name='overlap_list', example=''),
  // 重叠指数集合条数
  overlapListNum: string(name='overlap_list_num', example='2'),
  // 流入指数集合
  srcList: [ GdSrc ](name='src_list', example=''),
  // 流入指数条数
  srcListNum: string(name='src_list_num', example='2'),
  // 流出指数集合
  destList: GdDest(name='dest_list', example=''),
  // 流出指数条数
  destListNum: string(name='dest_list_num', example='2'),
}

