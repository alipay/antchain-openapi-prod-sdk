  periodNum: long(maximum=1000, name='period_num', example='1'),
  // 押金，单位：分。
  depositPrice: long(maximum=10000000, name='deposit_price', example='100000'),
  // 买断价格，单位：分
  buyoutPrice: long(maximum=10000000, name='buyout_price', example='100000'),
  // 首期租金，单位：分
  initialRentPrice: long(maximum=10000000, name='initial_rent_price', example='100000'),
}

// 订单消息结构体
model OrderMsgInfo {
  // 订单id
  // 
  orderId: string(name='order_id', example='13213123'),
  // 消息ID
  // 
  msgId: string(name='msg_id', example='79256C48A6004E1EA4E18AF06745DB0A'),
  // 消息类型
  // 
  msgPublishType: string(name='msg_publish_type', example='ORDER_STATUS_CHANGE'),
  // 消息创建时间
  // 
  msgCreateTime: string(pattern='\\\\d{4}[-]\\\\d{1,2}[-]\\\\d{1,2}[T]\\\\d{2}:\\\\d{2}:\\\\d{2}([Z]|([\\\\.]\\\\d{1,9})?[\\\\+]\\\\d{2}[\\\\:]?\\\\d{2})', name='msg_create_time', example='2018-10-10T10:10:00Z'),
  // 消息投递状态 SUCCESS 成功 FAIL 失败 WAIT 等待投递重试
  msgStatus: string(name='msg_status', example='SUCCESS'),
  // 消息重投次数
  // 
  msgRetryTime: long(name='msg_retry_time', example='1'),
  // 消息体内容
  msgContent: string(name='msg_content', example='{}'),
  // 消息回调地址
  msgCallbackUrl: string(name='msg_callback_url', example='https://hstest02.xd0.co/antchain/ato/notify'),
  // 新回调地址
  newMsgCallbackUrl: string(name='new_msg_callback_url', example='http://test'),
}

// 营销发奖风险识别入参模型
model AwardingQueryModel {
  // 对方支付宝账户 uid，用于表示两个账户在业务交互中的对方账户，如人传人活动用户A会拉用户B来注册领奖，其中用户B为对方账户
  opposingUserid?: string(maxLength=128, minLength=1, name='opposing_userid', example='208834525645xxxx'),
  // 对方支付宝账户openid，营销发奖风险识别场景，userid 与 open_id 至少传入一个
  opposingOpenId?: string(maxLength=128, minLength=1, name='opposing_open_id', example='021uU206oUtUsckXA1rpUpiWpFwNTOFzX00gV0PIrkWxxxx'),
  // 服务二级分类
  serviceCategory?: string(maxLength=128, minLength=1, name='service_category', example='category1'),
  // 服务商 pid
  isvPid?: string(maxLength=128, minLength=1, name='isv_pid', example='208834525645xxxx'),
  // 银行卡号
  bankCardNo?: string(maxLength=128, minLength=1, name='bank_card_no', example='6228xxxxxxxxxxxxx13'),
  // 手机序列号
  imei?: string(maxLength=128, minLength=1, name='imei', example='86573603141xxxx'),
  // 国际移动用户识别码
  imsi?: string(maxLength=128, minLength=1, name='imsi', example='46000123456xxxx'),
  // 金额，用户购买或使用服务时产生的具体金额，单位：分
  salesAmount?: long(maximum=10000000, minimum=1, name='sales_amount', example='1000'),
  // 用户姓名
  userName?: string(maxLength=128, minLength=1, name='user_name', example='张三'),
  // 门店行业类目，枚举值：CATERING - 餐饮；LEISURE - 休闲；MEDICAL - 医疗
  storeMccDesc?: string(maxLength=30, minLength=1, name='store_mcc_desc', example='CATERING'),
  // 消费者 id，外部会员账号
  customerId: string(maxLength=128, minLength=1, name='customer_id', example='1232xxxx'),
  // 填入想要咨询风控的二维码值，需为唯一值
  qrCode?: string(maxLength=256, minLength=1, name='qr_code', example='http://xxxxxx/b/26acfacxxxxxx'),
}

// 订单用户信息
model OrderUserInfo {
  // 承租人名称
  userName?: string(name='user_name', example='张三'),
  // 承租人手机号
  userPhoneNumber?: string(name='user_phone_number', example='12345678912'),
  // 地址
  userAddress?: string(name='user_address', example='四川成都'),
  // 支付宝账号
  alipayUid?: string(name='alipay_uid', example='2088123456789'),
  // 租赁类别
  // 1:个人用户
  // 2:企业用户
  lesseeType?: long(name='lessee_type', example='1'),
  // 承租人身份证
  userId?: string(name='user_id', example='6102384935948594'),
}

// 租户协议分页对象
model AgreementPage {
  // 协议id
  agreementId: string(name='agreement_id', example='1231234343423423'),
  // 代理企业名称
  merchantName: string(name='merchant_name', example='xx公司'),
  // 租户8位id
  tenantId: string(name='tenant_id', example='SADWQWAW'),
  // 业务类型 枚举
  productMainClass: string(name='product_main_class', example='业务类型'),
  // 协议类型 枚举
  agreementType: string(name='agreement_type', example='协议类型'),
  // 租户签约状态 枚举
  signStatus: string(name='sign_status', example='SUCCESS'),
}

// 资方后台融资结果
model FundMngLoanApplyResult {
  // 放款状态
  loanApplyStatus?: string(name='loan_apply_status', example='REJECTED_LOAN'),
  // 融资申请失败原因
  loanFailReason?: string(name='loan_fail_reason', example='xxx原因'),
}

// 签署人账户
model SignAccount {
  // 公司统一社会信用代码（userType=ORGANIZATION必传）
  companyId?: string(name='company_id', example='91310101MA1FPCXA3G'),
  // 公司角色（userType=ORGANIZATION必传） MERCHANT=商户;FINANCIER=资方
  companyRole?: string(name='company_role', example='MERCHANT'),
  // 用户姓名（userType=PERSON必传，需要RSA加密）
  userName?: string(name='user_name', example='RSA(用户姓名)'),
  // 用户身份证号（userType=PERSON必传，需要RSA加密）
  userIdNumber?: string(name='user_id_number', example='RSA(用户身份证号)'),
  // 签署人类型，PERSON=个人;ORGANIZATION=机构
  userType: string(name='user_type', example='PERSON'),
  // 用户邮箱（userType=PERSON必传，需要RSA加密）
  userEmail?: string(name='user_email', example='RSA(用户邮箱)'),
  // 用户手机号（userType=PERSON必传，需要RSA加密）
  userMobile?: string(name='user_mobile', example='RSA(用户手机号)'),
  // 签署标签（对应模版配置中的tag）
  tag: string(name='tag', example='jiafang'),
  // 是否获取签署链接
  getSignUrl?: boolean(name='get_sign_url', example='true, false'),
}

// 用信订单信息
model CreditUtilizationOrder {
  // 123
  orderId: string(maxLength=50, minLength=6, name='order_id', example='123'),
  // 订单用信额度，单位为分
  orderCreditLine: long(minimum=1, name='order_credit_line', example='100'),
  // 订单商户应还金额，单位为分
  orderMerchantRepaymentMoney: long(minimum=1, name='order_merchant_repayment_money', example='100'),
  // 分账起始日期
  divideStartTermIndex: long(minimum=1, name='divide_start_term_index', example='1'),
}

// 主动支付单据
model ActivePayOrder {
  // 支付宝支付订单号，用于拉起主动支付页面
  tradeNo: string(maxLength=64, minLength=1, name='trade_no', example='f28038577d664015bfc1034c4a125121'),
  // 状态
  // INIT：交易创建
  // FAILED：付款失败
  // SUCCESS：付款成功
  tradeStatus: string(maxLength=64, minLength=1, name='trade_status', example='INIT'),
  // 状态原因码
  statusReasonCode?: string(minLength=1, name='status_reason_code', example='TIMEOUT'),
  // 超时关闭
  statusReasonMsg?: string(minLength=1, name='status_reason_msg', example='状态原因描述'),
  // 本次交易支付的订单金额，单位为分
  // 付款成功或付款成功之后的状态必填
  totalAmount?: long(minimum=1, name='total_amount', example='100'),
  // 用户在交易中支付的金额，单位为分
  // 付款成功的状态必填
  paidAmount?: long(minimum=1, name='paid_amount', example='100'),
  // 商家在交易中实际收到的款项，单位为分
  // 付款成功的状态必填
  receiptAmount?: long(minimum=1, name='receipt_amount', example='100'),
  // 交易支付时间
  // 付款成功的状态必填
  gmtPay?: string(pattern='\\\\d{4}[-]\\\\d{1,2}[-]\\\\d{1,2}[T]\\\\d{2}:\\\\d{2}:\\\\d{2}([Z]|([\\\\.]\\\\d{1,9})?[\\\\+]\\\\d{2}[\\\\:]?\\\\d{2})', name='gmt_pay', example='2018-10-10T10:10:00Z'),
  // 支付单据创建时间
  gmtCreate?: string(pattern='\\\\d{4}[-]\\\\d{1,2}[-]\\\\d{1,2}[T]\\\\d{2}:\\\\d{2}:\\\\d{2}([Z]|([\\\\.]\\\\d{1,9})?[\\\\+]\\\\d{2}[\\\\:]?\\\\d{2})', name='gmt_create', example='2018-10-10T10:10:00Z'),
  // 多期合并支付明细
  multiPayDetail?: [ SingleTermDetail ](name='multi_pay_detail', example=''),
}

// 拒量模型
model RejectRiskModel {
