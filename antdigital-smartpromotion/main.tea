  // 规格图片
  largeSpecImageFileKey?: string(name='large_spec_image_file_key', example='["fileKey"]'),
  // 原订单总金额（单位分）
  originTotalRentMoney?: long(name='origin_total_rent_money', example='2'),
  // 现订单总金额（单位分）
  totalRentMoney?: long(name='total_rent_money', example='1'),
  // 原日租金（单位分）
  originDailyRentMoney?: long(name='origin_daily_rent_money', example=''),
  // 现日租金（单位分）
  dailyRentMoney?: long(name='daily_rent_money', example=''),
  // 库存
