  riskRank?: string(name='risk_rank', example='rank1'),
  // 流程id
  flowId: string(name='flow_id', example='10000009000001804441658067824640'),
  // 拒量模型捞回分
  mobThreeScore?: string(name='mob_three_score', example='0.00570491'),
  // 拒量模型首逾分
  fpdThirtyScore?: string(name='fpd_thirty_score', example='0.00570491'),
}

