  type?: string(name='type', example='NOTIFICATION'),
  // ("PENDING","待办中"),  ("CONFIRMED","确认"),  
  // ("REJECTED","已拒绝")
  // ("FAILED","失败"),("EXPIRED","已过期");
  status?: string(name='status', example='PENDING'),
