// 资产包履约计划分配明细
model AssetPackagePlanAllocateDetail {
  // 订单id
  orderId?: string(name='order_id', example='123'),
  // 商户租户id
  tenantId?: string(name='tenant_id', example='HXDRFKOF'),
  // 类型
  // PERFORMANCE 履约
  // ASSET_PACKAGE_EXCESS 资产包超额
  type?: string(name='type', example='ASSET_PACKAGE_EXCESS'),
  // 用户还款期数
  periodNum?: long(name='period_num', example='1'),
  // 用户还款时间yyyy-MM-dd
  payDay?: string(name='pay_day', example='2026-03-16'),
  // 用户还款金额，单位为分
  payAmount?: long(name='pay_amount', example='100'),
  // 分账比例(不存储实时计算)，保留两位小数，比例统一类型。
  divideRatio?: string(name='divide_ratio', example='20'),
  // 商户履约分账金额
  divideAmount?: long(name='divide_amount', example='100'),
}

// 应用信息
model ApplicationInfo {
