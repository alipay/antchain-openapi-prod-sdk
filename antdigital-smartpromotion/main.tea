// 行业黄牛风险识别入参模型
model ScalperQueryModel {
  // 注册手机号，填写咨询对象所关联的注册手机号
  registrationPhone?: string(maxLength=20, minLength=1, name='registration_phone', example='123xxxxxx56'),
  // 认证时间，填写风险咨询对象所关联的账号的真实身份认证时间
  certificateDate?: string(maxLength=20, minLength=1, name='certificate_date', example='2099-12-30 23:59:59'),
  // 登录手机号，填写风险咨询对象关联账号的登录手机号
  loginPhone?: string(maxLength=20, minLength=1, name='login_phone', example='123xxxxxx56'),
  // 注册账号身份证，填写风险咨询对象所关联账号的注册身份证信息
  registrationCert?: string(maxLength=30, minLength=1, name='registration_cert', example='123xxxxxxxxxx55'),
  // 登录账号身份证，登录账号的身份证号码
  loginCert?: string(maxLength=30, minLength=1, name='login_cert', example='230109xxxxxxxx3000'),
  // 注册时间，填写风险咨询对象所关联的账号的注册时间
  registrationDate?: string(maxLength=20, minLength=1, name='registration_date', example='2099-12-30 23:59:59'),
  // 证件类型；枚举值：1 - 身份证；2 - 护照
  certType?: long(maximum=2, minimum=1, name='cert_type', example='1'),
  // 银行卡号
  bankCardNo?: string(maxLength=50, minLength=1, name='bank_card_no', example='223940194399993xxxx'),
  // 用户邮箱
  emailAddress?: string(maxLength=35, minLength=1, name='email_address', example='zhifubaoxxxx@163.com'),
  // 手机序列号
  imei?: string(maxLength=100, minLength=1, name='imei', example='86573603141xxxx'),
  // 国际移动用户识别码
  imsi?: string(maxLength=100, minLength=1, name='imsi', example='46000123456xxxx'),
  // mac 地址或设备唯一标识
  macAddress?: string(maxLength=30, minLength=1, name='mac_address', example='42.118.71.72'),
  // 设备号，设备唯一号码
  apdid?: string(maxLength=128, minLength=1, name='apdid', example='qtedxaxxxxxxxx'),
  // 支付宝外部交易号
  outOrderNo?: string(maxLength=128, minLength=1, name='out_order_no', example='123xxxxxxxxxx55'),
  // 所咨询的唯一支付宝交易号
  orderNo?: string(maxLength=128, minLength=1, name='order_no', example='202304262200141025xxxxxx0000'),
  // 用户购买或使用服务时产生的具体金额总数，单位：分
  salesAmount?: long(maximum=1000000, minimum=1, name='sales_amount', example='3354'),
  // 用户姓名
  userName?: string(maxLength=50, minLength=1, name='user_name', example='张三'),
  // 收货手机号，用于区分 mobile_no 所填的手机号
  mailingPhone?: string(maxLength=20, minLength=1, name='mailing_phone', example='1380095xxxx'),
  // 收货地址
  mailingAddress?: string(maxLength=128, minLength=1, name='mailing_address', example='西溪路'),
  // 是否为员工账号，枚举值：1 - 是
  isEmployee?: string(maxLength=10, minLength=1, name='is_employee', example='1'),
  // 渠道，枚举值：alipay - 支付宝；app - 自有app；pc - 电脑端
  channel?: string(maxLength=10, minLength=1, name='channel', example='alipay'),
  // 服务商 pid
  isvPid?: string(maxLength=128, minLength=1, name='isv_pid', example='208850162456xxxx'),
  // 门店行业类目，枚举值：CATERING - 餐饮；LEISURE - 休闲；MEDICAL - 医疗
  storeMccDesc?: string(maxLength=20, minLength=1, name='store_mcc_desc', example='CATERING'),
  // 消费者 id，外部会员账号
  customerId?: string(maxLength=128, minLength=1, name='customer_id', example='12321123'),
  // 订单所有商品信息列表
  orderItemsInfoList?: [ ScalperQueryOrderItem ](name='order_items_info_list', example=''),
}

