// 资产包资金方案内容
model AssetPackageFinancePlan {
  // 版本号，从1开始
  version?: long(name='version', example='1'),
  // 状态，ENABLE：启用，不启用时默认null
  status?: string(name='status', example='ENABLE'),
  // 放款比例
  // 0~100，保留小数2位
  loanRate?: string(name='loan_rate', example='75'),
  // 放款金额，单位分
  loanMoney?: long(name='loan_money', example='100'),
  // 放款金额，单位元
  loanMoneyYuan?: string(name='loan_money_yuan', example='1.00'),
  // 计息方式，枚举：
  // ● 年化利率：APR
  // ● 固定金额：FIXED_AMOUNT
  // ● 固定比例：FIXED_RATE
  interestAccrualMethod?: string(name='interest_accrual_method', example='APR'),
  // 年计息天数
  dayCountConvention?: long(name='day_count_convention', example='360'),
  // 息费率
  allinFinancingCostRate?: string(name='allin_financing_cost_rate', example='7'),
  // 还款方式，枚举：
  // ● 等额本息：EQUAL_INSTALLMENT_METHOD
  repaymentMethod?: string(name='repayment_method', example='EQUAL_INSTALLMENT_METHOD'),
  // 还款频率，枚举：
  // ● 按月：MONTH
  repaymentFrequency?: string(name='repayment_frequency', example='MONTH'),
  // 融资期数，范围0~36
  financeNum?: long(name='finance_num', example='12'),
  // 计划还款日期，范围1～28
  payDay?: long(name='pay_day', example='20'),
  // 触发商家代偿时间，单位天
  merchantCompensationDay?: long(name='merchant_compensation_day', example='2'),
  // 订单未还款总金额，单位分
  unreleasedAmount?: long(name='unreleased_amount', example='100'),
}

