  // 风险等级。枚举值：RANK0-无法判断；RANK1-极低风险；RANK2-低风险；RANK3-中风险；RANK4-高风险；RANK5-极高风险。 
  riskRank: string(name='risk_rank', example='RANK0'),
  // 风险描述
  riskDesc: string(name='risk_desc', example='低风险'),
}

