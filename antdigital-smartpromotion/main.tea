  // 回购原因
  // ACTIVE_REDEEM("ACTIVE_REDEEM", "自主赎回"),
  // RENTING_OUT_REDEEM("RENTING_OUT_REDEEM",
  //                                                                           "退租赎回"),
  // RENTING_AND_RESALE_REDEEM("RENTING_AND_RESALE_REDEEM",
  //                                                                                  "租转售赎回");
  redeemReason?: string(name='redeem_reason', example='ACTIVE_REDEEM'),
  // 回购类型
  // TRANSFER，转账代偿
  // WITHHOLD，代扣代偿
  redeemType?: string(name='redeem_type', example='TRANSFER'),
  // 回购金额（分）
  redeemAmount?: long(name='redeem_amount', example='100'),
  // 回购状态
  // PAYING 回购中
  // SUCCESS 成功
  // FAILED 失败
  redeemStatus?: string(name='redeem_status', example='PAYING'),
}

