model PushRightsprodGrantrightsRequest = {
  // OAuth模式下的授权token
  authToken?: string(name='auth_token'),
  productInstanceId?: string(name='product_instance_id'),
  // 用户ID
  userId?: string(name='user_id'),
  // 手机号
  phoneNumber?: string(name='phone_number'),
  // 商户编码
  merchantNo?: string(name='merchant_no'),
  // 权益编码
  rightsCode: string(name='rights_code'),
  // 发放数量，可根据权益信息grantMulti判断是否可发多张
  grantNum?: long(name='grant_num'),
  // 外部发放订单号
  outGrantOrderNo: string(name='out_grant_order_no'),
  // 发放扩展信息，如活动ID等信息，暂时可以不传
  grantInfo?: string(name='grant_info'),
}

model PushRightsprodGrantrightsResponse = {
  // 请求唯一ID，用于链路跟踪和问题排查
  reqMsgId?: string(name='req_msg_id'),
  // 结果码，一般OK表示调用成功
  resultCode?: string(name='result_code'),
  // 异常信息的文本描述
  resultMsg?: string(name='result_msg'),
  // 发放状态：
  // GRANTING：发放处理中 GRANT_SUCCESS：发放成功 GRANT_FAIL：发放失败
  grantStatus?: string(name='grant_status'),
  // 过期时间
  expireTime?: string(pattern='\\\\d{4}[-]\\\\d{1,2}[-]\\\\d{1,2}[T]\\\\d{2}:\\\\d{2}:\\\\d{2}([Z]|([\\\\.]\\\\d{1,9})?[\\\\+]\\\\d{2}[\\\\:]?\\\\d{2})', name='expire_time'),
  // 生效时间
  effectTime?: string(pattern='\\\\d{4}[-]\\\\d{1,2}[-]\\\\d{1,2}[T]\\\\d{2}:\\\\d{2}:\\\\d{2}([Z]|([\\\\.]\\\\d{1,9})?[\\\\+]\\\\d{2}[\\\\:]?\\\\d{2})', name='effect_time'),
  // 发放订单明细数据
  orderDetails?: [ GrantOrderDetail ](name='order_details'),
}

/**
 * Description: 权益供应商权益发放spi
 * Summary: 权益供应商权益发放spi
 */
