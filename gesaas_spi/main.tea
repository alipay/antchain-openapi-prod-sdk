model CallbackRightsprodOperationRequest = {
  // OAuth模式下的授权token
  authToken?: string(name='auth_token'),
  productInstanceId?: string(name='product_instance_id'),
  // 权益编码
  rightsCode: string(name='rights_code'),
  // 券码
  voucherCode: string(name='voucher_code'),
  // 通知ID(幂等)
  notifyId: string(name='notify_id'),
  // 业务类型
  // V_REFUND（退款）
  // V_EXPIRE（过期）
  // V_INVALID（作废）
  // V_USE（使用）
  bizType: string(name='biz_type'),
  // 支付订单号
  payOrderNo?: string(name='pay_order_no'),
  // 券面额
  faceAmount?: string(name='face_amount'),
  // 流通金额（核销、退款时 金额）
  fluxAmount?: string(name='flux_amount'),
}

model CallbackRightsprodOperationResponse = {
  // 请求唯一ID，用于链路跟踪和问题排查
  reqMsgId?: string(name='req_msg_id'),
  // 结果码，一般OK表示调用成功
  resultCode?: string(name='result_code'),
  // 异常信息的文本描述
  resultMsg?: string(name='result_msg'),
  // 同步结果  
  // success 为同步成功其他均为失败
  result?: string(name='result'),
}

/**
 * Description: 券操作回调通知
