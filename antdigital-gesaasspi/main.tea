import AntchainUtil;
import Util;
import RPCUtil;

type @endpoint = string
type @regionId = string
type @accessKeyId = string
type @accessKeySecret = string
type @protocol = string
type @userAgent = string
type @readTimeout = number
type @connectTimeout = number
type @httpProxy = string
type @httpsProxy = string
type @socks5Proxy = string
type @socks5NetWork = string
type @noProxy = string
type @maxIdleConns = number
type @securityToken = string
type @maxIdleTimeMillis = number
type @keepAliveDurationMillis = number
type @maxRequests = number
type @maxRequestsPerHost = number

/**
 * Model for initing client
 */
model Config {
  accessKeyId?: string(description='accesskey id',default=''),
  accessKeySecret?: string(description='accesskey secret',default=''),
  securityToken?: string(description='security token',default=''),
  protocol?: string(description='http protocol',example='http',default='http'),
  readTimeout?: number(description='read timeout',example='10',default=''),
  connectTimeout?: number(description='connect timeout',example='10',default=''),
  httpProxy?: string(description='http proxy',example='http://localhost',default=''),
  httpsProxy?: string(description='https proxy',example='https://localhost',default=''),
  endpoint?: string(description='endpoint',example='cs.aliyuncs.com',default=''),
  noProxy?: string(description='proxy white list',example='http://localhost',default=''),
  maxIdleConns?: number(description='max idle conns',example='3',default=''),
  userAgent?: string(description='user agent',example='Alibabacloud/1',default=''),
  socks5Proxy?: string(description='socks5 proxy',default=''),
  socks5NetWork?: string(description='socks5 network',example='TCP',default=''),
  maxIdleTimeMillis?: number(description='长链接最大空闲时长',default='60 * 1000L'),
  keepAliveDurationMillis?: number(description='长链接最大连接时长',default='5000'),
  maxRequests?: number(description='最大连接数（长链接最大总数）',default='100'),
  maxRequestsPerHost?: number(description='每个目标主机的最大连接数（分主机域名的长链接最大总数',default='100'),
}

/**
 * Init client with Config
 * @param config config contains the necessary information to create a client
 */
init(config: Config) {
  if (Util.isUnset(config)) {
    throw {
      code = 'ParameterMissing',
      message = '\'config\' can not be unset'
    };
  }

  @accessKeyId = config.accessKeyId;
  @accessKeySecret = config.accessKeySecret;
  @securityToken = config.securityToken;
  @endpoint = config.endpoint;
  @protocol = config.protocol;
  @userAgent = config.userAgent;
  @readTimeout = Util.defaultNumber(config.readTimeout, 20000);
  @connectTimeout = Util.defaultNumber(config.connectTimeout, 20000);
  @httpProxy = config.httpProxy;
  @httpsProxy = config.httpsProxy;
  @noProxy = config.noProxy;
  @socks5Proxy = config.socks5Proxy;
  @socks5NetWork = config.socks5NetWork;
  @maxIdleConns = Util.defaultNumber(config.maxIdleConns, 60000);
  @maxIdleTimeMillis = Util.defaultNumber(config.maxIdleTimeMillis, 5);
  @keepAliveDurationMillis = Util.defaultNumber(config.keepAliveDurationMillis, 5000);
  @maxRequests = Util.defaultNumber(config.maxRequests, 100);
  @maxRequestsPerHost = Util.defaultNumber(config.maxRequestsPerHost, 100);
}

/**
 * Encapsulate the request and invoke the network
 * @param action api name
 * @param protocol http or https
 * @param method e.g. GET
 * @param pathname pathname of every api
 * @param request which contains request params
 * @param runtime which controls some details of call api, such as retry times
 * @return the response
 */
api doRequest(version: string, action: string, protocol: string, method: string, pathname: string, request: object, headers: map[string]string, runtime: Util.RuntimeOptions): object {
  __request.protocol = Util.defaultString(@protocol, protocol);
  __request.method = method;
  __request.pathname = pathname;
  __request.query = {
    method = action,
    version = version,
    sign_type = 'HmacSHA1',
    req_time = AntchainUtil.getTimestamp(),
    req_msg_id = AntchainUtil.getNonce(),
    access_key = @accessKeyId,
    base_sdk_version = 'TeaSDK-2.0',
    sdk_version = '1.5.1',
    _prod_code = 'GESAASSPI',
    _prod_channel = 'default'
  };

  if (!Util.empty(@securityToken)) {
    __request.query.security_token = @securityToken;
  }

  __request.headers = {
    host = Util.defaultString(@endpoint, 'openapi.antchain.antgroup.com'),
    user-agent = Util.getUserAgent(@userAgent),
    ...headers
  };

  var tmp = Util.anyifyMapValue(RPCUtil.query(request));
  __request.body = Util.toFormString(tmp);
  __request.headers.content-type = 'application/x-www-form-urlencoded';

  var signedParam = {
    ...__request.query,
    ...RPCUtil.query(request)
  };
  __request.query.sign = AntchainUtil.getSignature(signedParam, @accessKeySecret);
} returns {
  var raw = Util.readAsString(__response.body);
  var obj = Util.parseJSON(raw);
  var res = Util.assertAsMap(obj);
  var resp = Util.assertAsMap(res.response);

  if (AntchainUtil.hasError(raw, @accessKeySecret)) {
    throw {
      message = resp.result_msg,
      data = resp,
      code = resp.result_code
    };
  }
  return resp;
} runtime {
  timeouted = 'retry',
  readTimeout = Util.defaultNumber(runtime.readTimeout, @readTimeout),
  connectTimeout = Util.defaultNumber(runtime.connectTimeout, @connectTimeout),
  httpProxy = Util.defaultString(runtime.httpProxy, @httpProxy),
  httpsProxy = Util.defaultString(runtime.httpsProxy, @httpsProxy),
  noProxy = Util.defaultString(runtime.noProxy, @noProxy),
  maxIdleConns = Util.defaultNumber(runtime.maxIdleConns, @maxIdleConns),
  maxIdleTimeMillis = @maxIdleTimeMillis,
  keepAliveDuration = @keepAliveDurationMillis,
  maxRequests = @maxRequests,
  maxRequestsPerHost = @maxRequestsPerHost,
  retry = {
    retryable = runtime.autoretry,
    maxAttempts = Util.defaultNumber(runtime.maxAttempts, 3)
  },
  backoff = {
    policy = Util.defaultString(runtime.backoffPolicy, 'no'),
    period = Util.defaultNumber(runtime.backoffPeriod, 1)
  },
  ignoreSSL = runtime.ignoreSSL
}

// 【固定折扣特定信息】 
model FixedDiscountCoupon {
  // 【最高折扣金额】 最高折扣金额，单位分
  discountAmountMax: long(name='discount_amount_max', example='100'),
  // 【折扣百分比】 折扣百分比，例如88-八八折
  discountPercent: long(name='discount_percent', example='88'),
  // 【门槛】 使用券金额门槛，单位分
  transactionMinimum?: long(name='transaction_minimum', example='100'),
}

// 【固定面额批次特定信息】 固定面额发券或消费金批次特定信息。
model FixedNormalCoupon {
  // 【面额】 面额，单位：分。
  couponAmount: long(name='coupon_amount', example='100'),
  // 【门槛】 使用券金额门槛，单位：分。
  transactionMinimum: long(name='transaction_minimum', example='100'),
}

// 返回体度量
model RultMetric {
  // 度量编码
  metricCode: string(name='metric_code', example='ori_use_amount'),
  // 度量聚合结果
  metricValue: string(name='metric_value', example='21.22'),
}

// 【减至批次特定信息】 单品优惠特定信息
model CutToMessage {
  // 【可用优惠的商品最高单价】 可用优惠的商品最高单价，单位：分。
  singlePriceMax: long(name='single_price_max', example='100'),
  // 【减至后的优惠单价】 减至后的优惠单价，单位：分。
  cutToPrice: long(name='cut_to_price', example='80'),
}

// 【消费金可用地域】 消费金可用地域
model AvailableRegion {
  // 【类型】 消费金可用地域的类型，COUNTRY表示国家级别可用，PROVINCE表示省级可用，CITY表示市级可用，DISTRICT表示区级可用。
  // 可选取值
  // PROVINCE:  地域信息精确到省级
  // CITY:  地域信息精确到市级
  // DISTRICT:  地域信息精确到区级
  // COUNTRY:  地域信息精确到国家级
  type?: string(name='type', example='PROVINCE'),
  // 【省】 消费金可用省
  province?: string(name='province', example='广东省'),
  // 【市】 消费金可用
  city?: string(name='city', example='深圳市'),
  // 【区】 消费金可用区
  district?: string(name='district', example='南山区'),
  // 【国家】 消费金可用国家
  country?: string(name='country', example='中国大陆'),
}

// 维度
model Dimension {
  // 维度
  dimension: string(name='dimension', example='voucher_template_id'),
  // 维度值
  dimensionValue: string(name='dimension_value', example='2025122400073001038200J7964H'),
}

// 【满减券/消费金批次使用规则】 满减券或消费金批次特定信息。
model StockUseRule {
  // 【发放总上限】 最大发券数
  maxCoupons: long(name='max_coupons', example='100'),
  // 【总预算】 总消耗金额，单位：分。
  maxAmount: long(name='max_amount', example='5000'),
  // 【单天发放上限金额】 单天最高消耗金额，单位：分。
  maxAmountByDay: long(name='max_amount_by_day', example='400'),
  // 【固定面额批次特定信息】 固定面额发券或消费金批次特定信息。
  fixedNormalCoupon: FixedNormalCoupon(name='fixed_normal_coupon', example='{           "coupon_amount" : 100,           "transaction_minimum" : 100         }'),
  // 【单个用户可领个数】 单个用户可领个数
  maxCouponsPerUser: long(name='max_coupons_per_user', example='3'),
  // 【券或消费金类型】 券或消费金类型
  // 枚举值：
  // NORMAL：满减券
  // CUT_TO：减至券
  couponType?: string(name='coupon_type', example='NORMAL'),
  // 【订单优惠标记】 订单优惠标记 (该字段暂未开放返回)
  // 特殊规则：单个优惠标记的字符长度为【1，128】,条目个数限制为【1，50】。
  goodsTag?: [ string ](name='goods_tag', example='[           "123456"         ]'),
  // 【指定支付模式】默认不限制(该字段暂未开放返回)，枚举值：
  // 可选取值
  // MICROAPP:  小程序支付
  // APPPAY:  APP支付
  // PPAY:  免密支付
  // CARD:  刷卡支付
  // FACE:  人脸支付
  // OTHER:  其他支付，公众号、扫码等
  tradeType?: [ string ](name='trade_type', example='[           "MICROAPP"         ]'),
  // 【是否可叠加其他优惠】 枚举值：
  // true：是
  // false：否
  combineUse?: boolean(name='combine_use', example='true'),
  // 【固定折扣特定信息】
  fixedDiscountCoupon?: FixedDiscountCoupon(name='fixed_discount_coupon', example='{           "discount_amount_max" : 100,           "discount_percent" : 88,      "transaction_minimum" : 100         }'),
}

// 【批次详情】 批次详情
model WxStockData {
  // 【批次号】 微信为每个代金券批次分配的唯一id。
  stockId: string(name='stock_id', example='9836588'),
  // 【批次创建方商户号】 微信为创建方商户分配的商户号
  stockCreatorMchid: string(name='stock_creator_mchid', example='123456'),
  // 【批次名称】 批次名称
  stockName: string(name='stock_name', example='微信支付批次'),
  // 【批次状态】 批次状态，枚举值：
  // unactivated：未激活
  // audit：审核中
  // running：运行中
  // stoped：已停止
  // paused：暂停发放
  status: string(name='status', example='paused'),
  // 【创建时间】 批次创建时间，遵循rfc3339标准格式，格式为yyyy-MM-DDTHH:mm:ss.sss+TIMEZONE，yyyy-MM-DD表示年月日，T出现在字符串中，表示time元素的开头，HH:mm:ss.sss表示时分秒毫秒，TIMEZONE表示时区（+08:00表示东八区时间，领先UTC 8小时，即北京时间）。例如：2015-05-20T13:29:35.120+08:00表示，北京时间2015年5月20日 13点29分35秒。
  createTime: string(name='create_time', example='2015-05-20T13:29:35.120+08:00'),
  // 【使用说明】 批次描述信息
  description: string(name='description', example='微信支付营销'),
  // 【满减券/消费金批次使用规则】 满减券或消费金批次特定信息。
  stockUseRule?: StockUseRule(name='stock_use_rule', example='{         "max_coupons" : 100,         "max_amount" : 5000,         "max_amount_by_day" : 400,         "fixed_normal_coupon" : {           "coupon_amount" : 100,           "transaction_minimum" : 100         }'),
  // 【可用开始时间】 可用开始时间，遵循rfc3339标准格式，格式为yyyy-MM-DDTHH:mm:ss.sss+TIMEZONE，yyyy-MM-DD表示年月日，T出现在字符串中，表示time元素的开头，HH:mm:ss.sss表示时分秒毫秒，TIMEZONE表示时区（+08:00表示东八区时间，领先UTC 8小时，即北京时间）。例如：2015-05-20T13:29:35.120+08:00表示，北京时间2015年5月20日 13点29分35秒。
  availableBeginTime: string(name='available_begin_time', example='2015-05-20T13:29:35.120+08:00'),
  // 【可用结束时间】 可用结束时间，遵循rfc3339标准格式，格式为yyyy-MM-DDTHH:mm:ss.sss+TIMEZONE，yyyy-MM-DD表示年月日，T出现在字符串中，表示time元素的开头，HH:mm:ss.sss表示时分秒毫秒，TIMEZONE表示时区（+08:00表示东八区时间，领先UTC 8小时，即北京时间）。例如：2015-05-20T13:29:35.120+08:00表示，北京时间2015年5月20日 13点29分35秒。
  availableEndTime: string(name='available_end_time', example='2015-05-20T13:29:35.120+08:00'),
  // 【已发券或消费金数量】 已发券或消费金数量
  distributedCoupons: long(name='distributed_coupons', example='100'),
  // 【是否无资金流】 是否无资金流。枚举值：
  // true：是
  // false：否
  noCash: boolean(name='no_cash', example='true'),
  // 【激活批次的时间】 批次激活开启时间，遵循rfc3339标准格式，格式为yyyy-MM-DDTHH:mm:ss.sss+TIMEZONE，yyyy-MM-DD表示年月日，T出现在字符串中，表示time元素的开头，HH:mm:ss.sss表示时分秒毫秒，TIMEZONE表示时区（+08:00表示东八区时间，领先UTC 8小时，即北京时间）。例如：2015-05-20T13:29:35.120+08:00表示，北京时间2015年5月20日 13点29分35秒。
  startTime?: string(name='start_time', example='2015-05-20T13:29:35.120+08:00'),
  // 【终止批次的时间】 批次永久停止时间，遵循rfc3339标准格式，格式为yyyy-MM-DDTHH:mm:ss.sss+TIMEZONE，yyyy-MM-DD表示年月日，T出现在字符串中，表示time元素的开头，HH:mm:ss.sss表示时分秒毫秒，TIMEZONE表示时区（+08:00表示东八区时间，领先UTC 8小时，即北京时间）。例如：2015-05-20T13:29:35.120+08:00表示，北京时间2015年5月20日 13点29分35秒。
  stopTime?: string(name='stop_time', example='2015-05-20T13:29:35.120+08:00'),
  // 【减至批次特定信息】 单品优惠特定信息
  cutToMessage?: CutToMessage(name='cut_to_message', example='{         "single_price_max" : 100,         "cut_to_price" : 80       }'),
  // 【是否单品优惠】 枚举值：
  // true：是
  // false：否
  singleitem: boolean(name='singleitem', example='true'),
  // 【批次类型】 批次类型
  // 枚举值：
  // NORMAL：代金券批次
  // DISCOUNT_CUT：立减与折扣
  // OTHER：其他
  stockType: string(name='stock_type', example='NORMAL'),
  // 【卡包ID】 微信卡包ID
  cardId?: string(name='card_id', example='pX2-vjoeC94Nn-r2g5GjDwkfFH7E'),
  // 【业务类型】 细分业务类型，仅有当business_type=MULTIUSE时，才会返回，枚举值：
  // MULTIUSE：消费金
  // 可选取值
  // MULTIUSE:  消费金类型
  businessType?: string(name='business_type', example='MULTIUSE'),
  // 消费金可用地域列表，仅有当business_type=MULTIUSE时，才会返回
  availableRegionList?: [ AvailableRegion ](name='available_region_list', example='[         {           "type" : "PROVINCE",           "province" : "广东省",           "city" : "深圳市",           "district" : "南山区",           "country" : "中国大陆"         }       ]'),
  // 【消费金可用行业】 消费金可用行业列表，仅有当business_type=MULTIUSE时，才会返回
  availableIndustryList?: [ string ](name='available_industry_list', example='[         "餐饮"       ]'),
}

// 度量
model Metric {
  // 度量编码
  metricCode: string(name='metric_code', example='ori_use_amount'),
  // 计算列
  metricColumn: string(name='metric_column', example='ori_use_amount'),
  // 计算方式
  functionType?: string(name='function_type', example='SUM'),
}

// 业务号条件
model BizNoCondition {
  // 枚举
  // CITY 城市
  // BLOCK 区县
  // AGE 年龄
  dimension: string(name='dimension', example='100010'),
  // 枚举范围，每个维度的值是或的关系,需要校验场景和取值范围是否匹配
  // CITY:区划码
  // BLOCK:区划码（底包暂不支持）
  // AGE:30+、40+、50+（底包暂不支持
  valueScope: [ string ](name='value_scope', example='["100010","100011","100020"]'),
}

// 批处理结果
model BatchResult {
  // 业务号
  bizNo: string(maxLength=64, name='biz_no', example='业务号'),
  // 业务号类型
  bizNoType: string(maxLength=32, name='biz_no_type', example='PHONE_SHA1'),
  // 结果
  result?: string(name='result', example='Y'),
  // 结果码
  resultCode?: string(name='result_code', example='rights_rights-config-not-exist '),
}

// 任务详细结果包含任务的统计数据信息
model TaskDetailResult {
  // 总数量
  totalCount?: long(name='total_count', example='100'),
  // 成功数量
  successCount?: long(name='success_count', example='100'),
  // 失败数量
  failCount?: long(name='fail_count', example='0'),
  // 处理中数量
  processingCount?: long(name='processing_count', example='0'),
  // 当状态为无效时，显示具体的错误信息
  errorInfo?: string(name='error_info', example='xxx'),
}

// 聚合查询结果
model DwsResult {
  // 维度列表
  dimensionList: [ Dimension ](name='dimension_list', example=''),
  // 度量列表
  metricList: [ RultMetric ](name='metric_list', example=''),
}

// 过滤条件
model FilterCondition {
  // 过滤列
  filterColumn: string(name='filter_column', example='biz_date'),
  // 过滤方式
  filterType?: string(name='filter_type', example='BETWEEN'),
  // 值列表
  valueList: [ string ](name='value_list', example='["20240303", "20250303"]'),
}

// 地址，包含省、市、区(县)
model Address {
  // 市级
  city: string(maxLength=6, minLength=6, name='city', example='110100'),
  // 区、县级
  district?: string(maxLength=6, minLength=6, name='district', example='110101'),
}

// 发放订单明细
model GrantOrderDetail {
  // 券编码
  voucherCode: string(name='voucher_code', example='1798234932684395'),
}

// 键值对
model XNameValuePair {
  // 键名
  name: string(name='name', example='key'),
  // 键值
  value: string(name='value', example='value'),
}

model SubmitAntchainSdsScenedataTaskRequest = {
  // OAuth模式下的授权token
  authToken?: string(name='auth_token'),
  productInstanceId?: string(name='product_instance_id'),
  // 【场景】约定的场景枚举
  scene: string(maxLength=32, name='scene'),
  // 【业务号类型】该字段逐步废弃，枚举-PHONE_SHA1，PHONE_MD5
  bizNoType?: string(maxLength=32, name='biz_no_type'),
  // 【来源标识】适配客户的来源，可能是客户的任务/AK
  sourceMark?: string(maxLength=32, name='source_mark'),
  // 【动态参数】任务动态参数信息
  expectCondition?: [ BizNoCondition ](name='expect_condition'),
  // 【外部批次号】和任务类型组成唯一键
  outBatchNo?: string(name='out_batch_no'),
  // 【任务类型】SDS根据类型触发异步处理流程
  taskType?: string(name='task_type'),
}

model SubmitAntchainSdsScenedataTaskResponse = {
  // 请求唯一ID，用于链路跟踪和问题排查
  reqMsgId?: string(name='req_msg_id'),
  // 结果码，一般OK表示调用成功
  resultCode?: string(name='result_code'),
  // 异常信息的文本描述
  resultMsg?: string(name='result_msg'),
  // 创建任务成功后，返回批次号
  batchNo?: string(name='batch_no'),
}

/**
 * Description: 创建任务，获取批次号。
 * Summary: 创建任务，获取批次号。
 */
async function submitAntchainSdsScenedataTask(request: SubmitAntchainSdsScenedataTaskRequest): SubmitAntchainSdsScenedataTaskResponse {
  var runtime = new Util.RuntimeOptions{};
  var headers : map[string]string= {};
  return submitAntchainSdsScenedataTaskEx(request, headers, runtime);
}

